pipeline {
    agent any

    stages {

        stage('Clone Repo') {
            steps {
                echo 'Cloning repository'
            }
        }

        stage('Build Docker Image') {
            steps {
                bat 'docker build -t jenkins-demo-image .'
            }
        }

        stage('Run Container') {
            steps {
                bat 'docker run --name jenkins-demo-container jenkins-demo-image'
            }
        }

    }
}
